[
  {
    "_comment": "Example 1 — Single WMS layer, subdaily step (MTG Fire RGB, updates every 10 min)",
    "id": "timeline",
    "type": "Timeline",
    "title": "MTG Fire Temperature RGB",
    "target": "map_controls_bottom_center",
    "config_json": {
      "datasource": {
        "layer_ids": ["frp_mtg"]
      },
      "selectedIndex": "last",
      "refreshInterval": 600,
      "loop": true,
      "displayFormat": "{dd}-{mm}-{yyyy} {h}:{m}:{s}",
      "speed": 1,
      "stepOptions": [
        { "label": "10 min", "value": "PT10M" },
        { "label": "1 hour", "value": "PT1H"  }
      ],
      "showLegend": false,
      "hideLayerOnCollapse": false
    }
  },

  {
    "_comment": "Example 2 — Multiple WMS layers (MTG + MODIS). The widget computes the union of all TIME dimensions and controls all layers simultaneously.",
    "id": "timeline",
    "type": "Timeline",
    "title": "Fire RGB + MODIS Terra",
    "target": "map_controls_bottom_center",
    "config_json": {
      "datasource": {
        "layer_ids": ["frp_mtg", "modis_terra"]
      },
      "selectedIndex": "last",
      "refreshInterval": 600,
      "loop": true,
      "displayFormat": "{dd}-{mm}-{yyyy} {h}:{m}:{s}",
      "speed": 1,
      "stepOptions": [
        { "label": "10 min", "value": "PT10M" },
        { "label": "1 hour", "value": "PT1H"  },
        { "label": "1 day",  "value": "P1D"   }
      ]
    }
  },

  {
