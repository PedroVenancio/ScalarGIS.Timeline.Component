      "refreshInterval": 3600,
      "loop": false,
      "displayFormat": "{dd}-{mm}-{yyyy}",
      "speed": 1,
      "stepOptions": [
        { "label": "1 day", "value": "P1D" }
      ]
    }
  },

  {
    "_comment": "Example 5 — Daily historical WMS (MODIS Terra, NASA GIBS). Multi-range TIME dimension handled automatically.",
