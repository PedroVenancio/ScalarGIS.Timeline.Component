        "layer_ids": ["era5land_wind_10m"]
      },
      "selectedIndex": "last",
      "refreshInterval": 3600,
      "loop": false,
      "displayFormat": "{dd}-{mm}-{yyyy} {h}:{m}:{s}",
      "speed": 2,
      "stepOptions": [
        { "label": "1 hour",  "value": "PT1H" },
        { "label": "6 hours", "value": "PT6H" },
        { "label": "1 day",   "value": "P1D"  }
      ]
    },
    "_note_layer_config": {
      "_comment": "The WMTS layer config must use theme.layer (singular) for the ows:Identifier value.",
