  {
    "_comment": "Example 6 — Pre-defined time extent (skips GetCapabilities fetch). Useful when the server URL is slow or when the extent is already known.",
    "id": "timeline",
    "type": "Timeline",
    "title": "MTG Fire RGB (pre-defined extent)",
    "target": "map_controls_bottom_center",
    "config_json": {
      "datasource": {
        "layer_ids": ["frp_mtg"]
      },
      "selectedIndex": "last",
      "loop": true,
      "displayFormat": "{dd}-{mm}-{yyyy} {h}:{m}:{s}",
      "speed": 1,
      "stepOptions": [
        { "label": "10 min", "value": "PT10M" },
        { "label": "1 hour", "value": "PT1H"  }
      ]
    },
    "_note_layer_config": {
      "_comment": "Add a dimensions[] array to the layer config to pre-define the extent.",
      "id": "frp_mtg",
      "dimension_name": "time",
      "dimensions": [
        { "name": "time", "values": "2025-08-05T00:00:00Z/2026-04-17T14:30:00Z/PT10M" }
      ]
    }
  },

